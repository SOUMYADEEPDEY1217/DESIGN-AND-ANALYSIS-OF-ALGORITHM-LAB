#include <stdio.h>

int adj[20][20], visited[20], nodes;

void dfs(int v) {
    int i;
    printf("%d ", v);
    visited[v] = 1;

    for (i = 0; i < nodes; i++) {
        if (adj[v][i] == 1 && !visited[i]) {
            dfs(i);
        }
    }
}

int main() {
    int i, j, start;

    printf("Enter number of vertices: ");
    scanf("%d", &nodes);

    printf("Enter adjacency matrix:\n");
    for (i = 0; i < nodes; i++) {
        for (j = 0; j < nodes; j++) {
            scanf("%d", &adj[i][j]);
        }
    }

    for (i = 0; i < nodes; i++) {
        visited[i] = 0;
    }

    printf("Enter starting vertex (0 to %d): ", nodes - 1);
    scanf("%d", &start);

    printf("DFS Traversal: ");
    dfs(start);
    printf("\n");

    return 0;
}
