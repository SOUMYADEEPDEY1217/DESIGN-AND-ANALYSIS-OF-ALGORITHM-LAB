#include <stdio.h>
int max(int a, int b) {
return (a > b) ? a : b; }
void solveKnapsack(int W, int wt[], int val[], int n) {
    int i, w;
    int K[n + 1][W + 1];
    for (i = 0; i <= n; i++) {
        for (w = 0; w <= W; w++) {
            if (i == 0 || w == 0)
                K[i][w] = 0;
            else if (wt[i - 1] <= w)
                K[i][w] = max(val[i - 1] + K[i - 1][w - wt[i - 1]], K[i - 1][w]);
            else
                K[i][w] = K[i - 1][w];
        }
    }
    printf("Maximum Profit: %d\n", K[n][W]);
}
int main() {
    int profits[] = {2, 4, 7, 10};
    int weights[] = {1, 3, 5, 7};
    int capacity = 8;
    int n = sizeof(profits) / sizeof(profits[0]);
    solveKnapsack(capacity, weights, profits, n);
    return 0;
}
