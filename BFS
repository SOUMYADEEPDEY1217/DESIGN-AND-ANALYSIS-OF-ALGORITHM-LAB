#include <stdio.h>
#include <stdlib.h>

int main() {
    int nodes, i, j, start;
    int adj[20][20], visited[20] = {0}, queue[20];
    int front = -1, rear = -1;

    printf("Enter number of vertices: ");
    scanf("%d", &nodes);

    printf("Enter adjacency matrix:\n");
    for (i = 0; i < nodes; i++) {
        for (j = 0; j < nodes; j++) {
            scanf("%d", &adj[i][j]);
        }
    }

    printf("Enter starting vertex (0 to %d): ", nodes - 1);
    scanf("%d", &start);

    printf("BFS Traversal: ");
    
    visited[start] = 1;
    queue[++rear] = start;

    while (front != rear) {
        int current = queue[++front];
        printf("%d ", current);

        for (i = 0; i < nodes; i++) {
            if (adj[current][i] == 1 && !visited[i]) {
                queue[++rear] = i;
                visited[i] = 1;
            }
        }
    }

    printf("\n");
    return 0;
}
